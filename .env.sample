# PDF2MD 環境変数設定
# このファイルを .env にコピーして値を設定してください:
#   copy .env.sample .env
#
# .env ファイルは .gitignore に含まれているためリポジトリにはコミットされません。

# Claude API キー（図表・フローチャートのAI解析に使用）
# https://console.anthropic.com/ で取得
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# MarkItDown OCR plugin (OpenAI-compatible vision OCR)
# OPENAI_API_KEY is used when running: python pdf2md.py --layout markitdown ...
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: defaults to gpt-4o when omitted
MARKITDOWN_LLM_MODEL=gpt-4o
